{
  "expo": {
    "name": "ClearSkin AI",
    "slug": "clearskin-ai",
    "scheme": "clearskinai",
    "web": {
      "bundler": "metro"
    },
    "version": "2.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#10B981"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.clearskin.ai",
      "infoPlist": {
        "NSCameraUsageDescription": "We use the camera to capture your face photos for skin analysis."
      }
    },
    "android": {
      "permissions": [
        "CAMERA"
      ],
      "package": "com.clearskin.ai",
      "versionCode": 5
    },
    "plugins": [
      "expo-router",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.clearskin.ai",
          "enableGooglePay": true
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "05dacea1-7feb-4e58-b883-415073689e14"
      }
    },
    "owner": "teddy2s6"
  }
}
